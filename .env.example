# ── Gemini ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── Phoenix / Arize ──────────────────────────────────────────────────────────
# Local Phoenix (default when running `phoenix serve`)
PHOENIX_ENDPOINT=http://localhost:6006

# Arize Cloud Phoenix (uncomment if using hosted version)
# PHOENIX_ENDPOINT=https://app.phoenix.arize.com
# PHOENIX_API_KEY=your_phoenix_api_key_here

# ── EvalForge Settings ───────────────────────────────────────────────────────
# How many traces to pull per run
EVALFORGE_TRACE_LIMIT=500

# Minimum failure score to consider a trace a "failure" (0.0 - 1.0)
# Traces with score BELOW this threshold are treated as failures
EVALFORGE_FAILURE_THRESHOLD=0.5

# Number of clusters to find (set to 0 for auto-detection)
EVALFORGE_NUM_CLUSTERS=0

# Number of eval cases to generate per cluster
EVALFORGE_CASES_PER_CLUSTER=10

# Output directory for generated evals
EVALFORGE_OUTPUT_DIR=./output

# ── UI Settings ──────────────────────────────────────────────────────────────
EVALFORGE_UI_HOST=0.0.0.0
EVALFORGE_UI_PORT=8000
